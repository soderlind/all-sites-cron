{
	"name": "soderlind/all-sites-cron",
	"description": "Run wp-cron on all public sites in a multisite network",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/soderlind/all-sites-cron",
	"authors": [
		{
			"name": "Per Søderlind",
			"email": "per@soderlind.no",
			"homepage": "https://soderlind.no"
		}
	],
	"keywords": [
		"wordpress",
		"wp",
		"multisite",
		"cron",
		"github actions"
	],
	"support": {
		"issues": "https://github.com/soderlind/all-sites-cron/issues"
	},
	"autoload": {
		"psr-4": {
			"Soderlind\\Multisite\\AllSitesCron\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Soderlind\\Multisite\\AllSitesCron\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.0",
		"yahnis-elsts/plugin-update-checker": "^5.6"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6 || ^10.5",
		"brain/monkey": "^2.6"
	},
	"scripts": {
		"test": "phpunit"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}